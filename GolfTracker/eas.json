{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": true,
        "scheme": "DaddyCaddy",
        "appExtensions": [
          {
            "targetName": "GolfRoundWidget",
            "bundleIdentifier": "com.daddycaddy.golf.golf-round-widget"
          }
        ]
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": true,
        "scheme": "DaddyCaddy",
        "appExtensions": [
          {
            "targetName": "GolfRoundWidget",
            "bundleIdentifier": "com.daddycaddy.golf.golf-round-widget"
          }
        ]
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m-medium",
        "autoIncrement": true,
        "scheme": "DaddyCaddy",
        "appExtensions": [
          {
            "targetName": "GolfRoundWidget",
            "bundleIdentifier": "com.daddycaddy.golf.golf-round-widget"
          }
        ]
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
